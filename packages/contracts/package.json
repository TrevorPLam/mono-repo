{
  "name": "@repo/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Shared schemas, types, and validation contracts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./analytics": {
      "types": "./dist/analytics.d.ts",
      "import": "./dist/analytics.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "import": "./dist/database.js"
    },
    "./seo": {
      "types": "./dist/seo.d.ts",
      "import": "./dist/seo.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "tsup": {
    "entry": {
      "index": "src/index.ts",
      "analytics": "src/analytics.ts",
      "auth": "src/auth.ts",
      "database": "src/database.ts",
      "seo": "src/seo.ts"
    },
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
