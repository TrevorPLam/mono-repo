{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://design-tokens.repo/schemas/theme-file.schema.json",
  "title": "Theme File Schema",
  "description": "Validates theme overlay files",
  "type": "object",
  "properties": {
    "$description": {
      "type": "string",
      "description": "Description of the theme overlay"
    }
  },
  "patternProperties": {
    "^(surface|text|border|icon|focus|interactive)$": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "oneOf": [
            {
              "type": "object",
              "patternProperties": {
                "^[a-zA-Z][a-zA-Z0-9_]*$": {
                  "$ref": "#/definitions/semanticToken"
                }
              },
              "additionalProperties": false
            },
            {
              "$ref": "#/definitions/semanticToken"
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "semanticToken": {
      "type": "object",
      "properties": {
        "$value": {
          "type": "string",
          "pattern": "^\\{[a-zA-Z][a-zA-Z0-9._]*\\}$",
          "description": "Reference to core or semantic token"
        },
        "$type": {
          "type": "string",
          "enum": ["color", "dimension", "fontFamily", "fontWeight", "number", "duration", "cubicBezier", "shadow", "strokeWidth", "strokeStyle"],
          "description": "Token type"
        },
        "$description": {
          "type": "string",
          "description": "Token description"
        }
      },
      "required": ["$value", "$type"],
      "additionalProperties": false
    }
  }
}
