{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://design-tokens.repo/schemas/token-file.schema.json",
  "title": "Design Token File Schema",
  "description": "Validates raw token files under tokens/core and tokens/semantic",
  "type": "object",
  "properties": {
    "$description": {
      "type": "string",
      "description": "Description of the token file purpose"
    },
    "$type": {
      "type": "string",
      "enum": ["color", "dimension", "fontFamily", "fontWeight", "number", "duration", "cubicBezier", "shadow", "strokeWidth", "strokeStyle"],
      "description": "Default type for tokens in this file"
    }
  },
  "patternProperties": {
    "^[a-zA-Z][a-zA-Z0-9_]*$": {
      "oneOf": [
        {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z][a-zA-Z0-9_]*$": {
              "$ref": "#/definitions/token"
            }
          },
          "additionalProperties": false
        },
        {
          "$ref": "#/definitions/token"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "token": {
      "type": "object",
      "properties": {
        "$value": {
          "description": "Token value"
        },
        "$type": {
          "type": "string",
          "enum": ["color", "dimension", "fontFamily", "fontWeight", "number", "duration", "cubicBezier", "shadow", "strokeWidth", "strokeStyle"],
          "description": "Token type"
        },
        "$description": {
          "type": "string",
          "description": "Token description"
        },
        "$deprecated": {
          "type": "boolean",
          "description": "Whether token is deprecated"
        }
      },
      "required": ["$value", "$type"],
      "additionalProperties": false
    },
    "tokenValue": {
      "oneOf": [
        {
          "type": "string",
          "description": "String token value"
        },
        {
          "type": "number",
          "description": "Number token value"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array token value (e.g., fontFamily)"
        }
      ]
    }
  }
}
