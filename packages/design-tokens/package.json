{
  "name": "@repo/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Design token infrastructure with validation and CSS generation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "types": "./dist/css.d.ts",
      "import": "./dist/css.js"
    },
    "./css/index": {
      "types": "./dist/css/generator.d.ts",
      "import": "./dist/css/generator.js"
    },
    "./ts": {
      "types": "./dist/ts/index.d.ts",
      "import": "./dist/ts/index.js"
    },
    "./vanilla-extract": {
      "types": "./dist/vanilla-extract/index.d.ts",
      "import": "./dist/vanilla-extract/index.js"
    },
    "./global.css": "./src/generated/global.css",
    "./tokens.css": "./src/generated/tokens.css",
    "./themes.css": "./src/generated/themes.css",
    "./tailwind.css": "./src/generated/tailwind.css"
  },
  "scripts": {
    "build": "pnpm validate && pnpm build:tokens && tsup",
    "build:tokens": "node scripts/generate-simple-css.mjs",
    "validate": "node scripts/validate-tokens.mjs",
    "dev": "node scripts/generate-css.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist src/generated"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.15.0",
    "style-dictionary": "^3.9.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "tsup": {
    "entry": {
      "index": "src/index.ts",
      "css/index": "src/css/index.ts",
      "ts/index": "src/ts/index.ts",
      "vanilla-extract/index": "src/vanilla-extract/index.ts"
    },
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true
  },
  "sideEffects": [
    "./src/generated/**/*.css",
    "./global.css",
    "./tokens.css",
    "./themes.css",
    "./tailwind.css"
  ]
}
