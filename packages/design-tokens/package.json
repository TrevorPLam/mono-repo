{
  "name": "@repo/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Design token infrastructure with validation and CSS generation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "import": "./dist/themes.js"
    },
    "./css": {
      "types": "./dist/css.d.ts",
      "import": "./dist/css.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsup && pnpm generate:css",
    "build:css": "pnpm generate:css",
    "generate:css": "tsx scripts/generate-css.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "tokens:validate": "node dist/validate.js",
    "tokens:build": "pnpm build"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "@vanilla-extract/css": "^1.15.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0"
  },
  "tsup": {
    "entry": {
      "index": "src/index.ts",
      "tokens": "src/tokens/index.ts",
      "themes": "src/themes/index.ts",
      "schema": "src/schema/index.ts"
    },
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
